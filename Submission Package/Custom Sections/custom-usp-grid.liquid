{% comment %}
  Custom USP Grid Section
  Created for Digital Heroes Shopify Developer Trial
  Conforms to strict Liquid and JS standards.
{% endcomment %}

<div id="AuraUspGrid-{{ section.id }}" class="aura-usp-grid-container page-width">
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="aug-header">
      {% if section.settings.heading != blank %}
        <h2 class="aug-title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="aug-subtitle">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="aug-grid">
    {% for block in section.blocks %}
      <div class="aug-card" {{ block.shopify_attributes }}>
        <div class="aug-icon-wrapper" style="background-color: {{ section.settings.icon_bg_color }}; color: {{ section.settings.icon_color }};">
          {% if block.settings.custom_svg != blank %}
            <div class="aug-svg-icon">
              {{ block.settings.custom_svg }}
            </div>
          {% elsif block.settings.image_icon != blank %}
            <img
              src="{{ block.settings.image_icon | img_url: '100x100' }}"
              alt="{{ block.settings.image_icon.alt | escape }}"
              loading="lazy"
              width="50"
              height="50"
            >
          {% else %}
            {% comment %} Fallback default icon (star) {% endcomment %}
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% endif %}
        </div>
        <h3 class="aug-card-title">{{ block.settings.title | escape }}</h3>
        <p class="aug-card-text">{{ block.settings.text | escape }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% style %}
#AuraUspGrid-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.bg_color }};
}

#AuraUspGrid-{{ section.id }} .aug-header {
  text-align: center;
  margin-bottom: 40px;
}

#AuraUspGrid-{{ section.id }} .aug-title {
  margin: 0 0 10px 0;
  color: {{ section.settings.text_color }};
  font-family: var(--font-heading-family);
  font-style: var(--font-heading-style);
  font-weight: var(--font-heading-weight);
}

#AuraUspGrid-{{ section.id }} .aug-subtitle {
  margin: 0;
  font-size: 1.6rem;
  color: #64748B;
}

#AuraUspGrid-{{ section.id }} .aug-grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: 30px;
}

#AuraUspGrid-{{ section.id }} .aug-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 24px;
  background-color: #FFFFFF;
  border-radius: 8px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.05);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

#AuraUspGrid-{{ section.id }} .aug-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
}

#AuraUspGrid-{{ section.id }} .aug-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  margin-bottom: 20px;
}

#AuraUspGrid-{{ section.id }} .aug-svg-icon svg {
  display: block;
  width: 24px;
  height: 24px;
}

#AuraUspGrid-{{ section.id }} .aug-card img {
  object-fit: contain;
}

#AuraUspGrid-{{ section.id }} .aug-card-title {
  margin: 0 0 10px 0;
  font-size: 1.8rem;
  font-weight: 600;
  color: {{ section.settings.text_color }};
}

#AuraUspGrid-{{ section.id }} .aug-card-text {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.6;
  color: {{ section.settings.text_color }};
  opacity: 0.75;
}

@media screen and (max-width: 989px) {
  #AuraUspGrid-{{ section.id }} .aug-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 749px) {
  #AuraUspGrid-{{ section.id }} .aug-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Interactive USP Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Choose AURA"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Pure ingredients, intelligent design, clean wellness"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8FAFC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0F172A"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Background Color",
      "default": "#FEF3C7"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#D97706"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns on Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_icon",
          "label": "Image Icon (Optional)"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code (Optional)",
          "info": "Paste standard raw SVG code here. Make sure it uses stroke='currentColor' or fill='currentColor' for styling."
        },
        {
          "type": "text",
          "id": "title",
          "label": "USP Title",
          "default": "Premium Quality"
        },
        {
          "type": "text",
          "id": "text",
          "label": "USP Description",
          "default": "Describe your unique selling proposition in 10-15 words."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Interactive USP Grid",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "title": "100% Organic & Pure",
            "text": "Therapeutic-grade essential oils directly sourced from organic-certified growers worldwide."
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Sleek & Silent Design",
            "text": "Premium dome ceramic cover with silent ultrasonic vibrations to soothe without noise."
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Eco-Conscious Promise",
            "text": "Cruelty-free botanical formulas, recyclable amber glass bottles, carbon-offset shipping."
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Satisfaction Guaranteed",
            "text": "30-day trial period on diffusers and hassle-free return shipping on mists."
          }
        }
      ]
    }
  ]
}
{% endschema %}
