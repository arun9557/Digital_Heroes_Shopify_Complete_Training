{% comment %}
  Custom Before / After Image Slider
  Created for Digital Heroes Shopify Developer Trial
  Conforms to strict Liquid and JS standards.
{% endcomment %}

<div id="AuraBeforeAfter-{{ section.id }}" class="aura-before-after-container page-width">
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="aba-header">
      {% if section.settings.heading != blank %}
        <h2 class="aba-title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="aba-subtitle">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="aba-slider-wrapper">
    <div class="aba-slider" id="abaSlider-{{ section.id }}">
      <div class="aba-image-after">
        {% if section.settings.image_after != blank %}
          <img
            src="{{ section.settings.image_after | img_url: '1200x' }}"
            alt="{{ section.settings.image_after.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image_after.width }}"
            height="{{ section.settings.image_after.height }}"
          >
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'aba-placeholder' }}
        {% endif %}
        <span class="aba-label aba-label-after">{{ section.settings.label_after | escape }}</span>
      </div>

      <div class="aba-image-before">
        {% if section.settings.image_before != blank %}
          <img
            src="{{ section.settings.image_before | img_url: '1200x' }}"
            alt="{{ section.settings.image_before.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image_before.width }}"
            height="{{ section.settings.image_before.height }}"
          >
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'aba-placeholder' }}
        {% endif %}
        <span class="aba-label aba-label-before">{{ section.settings.label_before | escape }}</span>
      </div>

      <input 
        type="range" 
        min="0" 
        max="100" 
        value="50" 
        class="aba-slider-control" 
        aria-label="Slider Control"
        id="abaControl-{{ section.id }}"
      >
      
      <div class="aba-slider-line" aria-hidden="true">
        <div class="aba-slider-button">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="8 18 2 12 8 6"></polyline>
            <polyline points="16 6 22 12 16 18"></polyline>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

{% style %}
#AuraBeforeAfter-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

#AuraBeforeAfter-{{ section.id }} .aba-header {
  text-align: center;
  margin-bottom: 30px;
}

#AuraBeforeAfter-{{ section.id }} .aba-title {
  margin: 0 0 10px 0;
  font-family: var(--font-heading-family);
  font-style: var(--font-heading-style);
  font-weight: var(--font-heading-weight);
}

#AuraBeforeAfter-{{ section.id }} .aba-subtitle {
  margin: 0;
  font-size: 1.6rem;
  color: #64748B;
}

#AuraBeforeAfter-{{ section.id }} .aba-slider-wrapper {
  position: relative;
  width: 100%;
  max-width: 1000px;
  margin: 0 auto;
  overflow: hidden;
  border-radius: 12px;
  box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
}

#AuraBeforeAfter-{{ section.id }} .aba-slider {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
  user-select: none;
}

#AuraBeforeAfter-{{ section.id }} .aba-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #E2E8F0;
}

#AuraBeforeAfter-{{ section.id }} .aba-image-after,
#AuraBeforeAfter-{{ section.id }} .aba-image-before {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

#AuraBeforeAfter-{{ section.id }} .aba-image-after img,
#AuraBeforeAfter-{{ section.id }} .aba-image-before img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

#AuraBeforeAfter-{{ section.id }} .aba-image-before {
  width: 50%;
  overflow: hidden;
  z-index: 2;
}

#AuraBeforeAfter-{{ section.id }} .aba-image-before img {
  width: 200%;
  max-width: none;
}

#AuraBeforeAfter-{{ section.id }} .aba-label {
  position: absolute;
  bottom: 20px;
  padding: 6px 12px;
  background: rgba(30, 41, 59, 0.8);
  color: #FFFFFF;
  font-size: 1.2rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  border-radius: 4px;
  z-index: 3;
}

#AuraBeforeAfter-{{ section.id }} .aba-label-before {
  left: 20px;
}

#AuraBeforeAfter-{{ section.id }} .aba-label-after {
  right: 20px;
}

#AuraBeforeAfter-{{ section.id }} .aba-slider-control {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: ew-resize;
  z-index: 5;
  margin: 0;
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  border: none;
}

#AuraBeforeAfter-{{ section.id }} .aba-slider-control::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 44px;
  height: 44px;
  cursor: ew-resize;
}

#AuraBeforeAfter-{{ section.id }} .aba-slider-control::-moz-range-thumb {
  width: 44px;
  height: 44px;
  cursor: ew-resize;
  border: none;
  background: transparent;
}

#AuraBeforeAfter-{{ section.id }} .aba-slider-line {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2px;
  background-color: #FFFFFF;
  z-index: 4;
  pointer-events: none;
  transform: translateX(-50%);
}

#AuraBeforeAfter-{{ section.id }} .aba-slider-button {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background-color: #FFFFFF;
  color: #1E293B;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

@media screen and (max-width: 749px) {
  #AuraBeforeAfter-{{ section.id }} .aba-slider {
    aspect-ratio: 4/3;
  }
}
{% endstyle %}

<script>
  (function() {
    function initSlider() {
      const section = document.querySelector('#AuraBeforeAfter-{{ section.id }}');
      if (!section) return;

      const slider = section.querySelector('#abaSlider-{{ section.id }}');
      const control = section.querySelector('#abaControl-{{ section.id }}');
      const beforeImgContainer = section.querySelector('.aba-image-before');
      const beforeImg = beforeImgContainer.querySelector('img, svg');
      const sliderLine = section.querySelector('.aba-slider-line');

      if (!slider || !control || !beforeImgContainer || !sliderLine) return;

      function updateSlider() {
        const value = control.value;
        beforeImgContainer.style.width = value + '%';
        sliderLine.style.left = value + '%';
        
        // Adjust the cropped image scale to match the container width
        if (beforeImg) {
          const containerWidth = slider.offsetWidth;
          beforeImg.style.width = containerWidth + 'px';
        }
      }

      control.addEventListener('input', updateSlider);
      window.addEventListener('resize', updateSlider);
      
      // Initial call to set widths correctly on load
      setTimeout(updateSlider, 100);
    }

    document.addEventListener('DOMContentLoaded', initSlider);
    if (Shopify.designMode) {
      document.addEventListener('shopify:section:load', initSlider);
    }
  })();
</script>

{% schema %}
{
  "name": "Before/After Image Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Difference"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Drag the slider to compare"
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Before Image"
    },
    {
      "type": "text",
      "id": "label_before",
      "label": "Before Label",
      "default": "Before"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "After Image"
    },
    {
      "type": "text",
      "id": "label_after",
      "label": "After Label",
      "default": "After"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Before/After Image Slider"
    }
  ]
}
{% endschema %}
